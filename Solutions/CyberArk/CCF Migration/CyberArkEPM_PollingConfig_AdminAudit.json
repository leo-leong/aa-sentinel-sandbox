[
  {
    "type": "Microsoft.SecurityInsights/dataConnectors",
    "apiVersion": "2023-02-01-preview",
    "name": "CyberArkEPMAdminAuditConnector",
    "location": "{{location}}",
    "kind": "RestApiPoller",
    "properties": {
      "connectorDefinitionName": "CyberArkEPMConnectorDefinition",
      "dataType": "CyberArkEPMAdminAudit_CL",
      "dcrConfig": {
        "streamName": "Custom-CyberArkEPMAdminAudit_CL",
        "dataCollectionEndpoint": "{{dataCollectionEndpoint}}",
        "dataCollectionRuleImmutableId": "{{dataCollectionRuleImmutableId}}"
      },
      "auth": {
        "type": "OAuth2",
        "GrantType": "client_credentials",
        "ClientId": "{{clientId}}",
        "ClientSecret": "{{clientSecret}}",
        "TokenEndpoint": "{{identityEndpoint}}/oauth2/token/{{webAppId}}",
        "TokenEndpointHeaders": {
          "Content-Type": "application/x-www-form-urlencoded"
        }
      },
      "request": {
        "apiEndpoint": "{{BaseUrl}}/EPM/API/Sets",
        "httpMethod": "GET",
        "queryTimeFormat": "yyyy-MM-ddTHH:mm:ssZ",
        "rateLimitQPS": 10,
        "queryWindowInMin": 60,
        "queryWindowDelayInMin": 10,
        "retryCount": 3,
        "timeoutInSeconds": 60,
        "headers": {
          "Content-Type": "application/json",
          "x-cybr-telemetry": "aW49TWljcm9zb2Z0IFNlbnRpbmVsIEVQTSZpdj0yLjAmdm49TWljcm9zb2Z0Jml0PVNJTSE="
        }
      },
      "response": {
        "eventsJsonPaths": [ "$.Sets" ],
        "format": "json"
      },
      "stepInfo": {
        "stepType": "Nested",
        "nextSteps": [
          {
            "stepId": "fetchAdminAudit",
            "stepPlaceholdersParsingKql": "source | project _SetId = tostring(Id)"
          }
        ]
      },
      "stepCollectorConfigs": {
        "fetchAdminAudit": {
          "request": {
            "apiEndpoint": "{{BaseUrl}}/EPM/API/Sets/$_SetId$/AdminAudit",
            "httpMethod": "GET",
            "queryTimeFormat": "yyyy-MM-ddTHH:mm:ssZ",
            "rateLimitQPS": 10,
            "queryWindowInMin": 60,
            "queryWindowDelayInMin": 10,
            "retryCount": 3,
            "timeoutInSeconds": 60,
            "headers": {
              "Content-Type": "application/json",
              "x-cybr-telemetry": "aW49TWljcm9zb2Z0IFNlbnRpbmVsIEVQTSZpdj0yLjAmdm49TWljcm9zb2Z0Jml0PVNJTSE="
            },
            "StartTimeAttributeName": "DateFrom",
            "EndTimeAttributeName": "DateTo",
            "queryParameters": {
              "limit": "100",
              "offset": "0"
            }
          },
          "paging": {
            "pagingType": "Offset",
            "offsetParaName": "offset",
            "pageSize": 100,
            "pageSizeParameterName": "limit"
          },
          "response": {
            "eventsJsonPaths": [ "$.AdminAudits" ],
            "format": "json"
          }
        }
      }
    }
  }
]
